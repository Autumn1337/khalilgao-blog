---
import Figure from './Figure.astro';
import type { ImageMetadata } from 'astro';

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  noCushion?: boolean;
}

const { src, alt, caption, width = 960, height, noCushion } = Astro.props;
---

<Figure
  src={src}
  alt={alt}
  caption={caption}
  width={width}
  height={height}
  noCushion={noCushion}
  wide
/>
