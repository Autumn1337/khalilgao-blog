---
export interface Props {
  headings: Array<{ depth: number; text: string; slug: string }>;
  /** Override label, default "目录". */
  label?: string;
  /** Skip the "目录" label row (useful when the parent container already
      carries its own label, e.g. the mobile `<details><summary>目录`). */
  hideLabel?: boolean;
  /** Override the landmark aria-label. Default "文章目录". Used to
      disambiguate the desktop sidebar TOC from the mobile <details>
      TOC when both exist in the DOM at the same time. */
  ariaLabel?: string;
}

const {
  headings,
  label = '目录',
  hideLabel = false,
  ariaLabel = '文章目录',
} = Astro.props;

/** Group H3 under their nearest preceding H2 so the TOC can collapse H3
 *  entries by default and only reveal the section currently being read. */
type H2Node = {
  h2: Props['headings'][number];
  children: Props['headings'];
};

const tree: H2Node[] = [];
let cursor: H2Node | null = null;
for (const h of headings) {
  if (h.depth === 2) {
    cursor = { h2: h, children: [] };
    tree.push(cursor);
  } else if (h.depth === 3 && cursor) {
    cursor.children.push(h);
  }
}
---

{tree.length > 0 && (
  <nav class="toc" aria-label={ariaLabel}>
    {!hideLabel && <p class="toc__label">{label}</p>}
    <ol class="toc__list">
      {tree.map((node) => (
        <li
          class="toc__item"
          data-depth="2"
          data-slug={node.h2.slug}
        >
          <a href={`#${node.h2.slug}`} data-toc-link={node.h2.slug}>
            {node.h2.text}
          </a>
          {node.children.length > 0 && (
            <ol class="toc__sub">
              {node.children.map((c) => (
                <li
                  class="toc__item"
                  data-depth="3"
                  data-slug={c.slug}
                  data-parent={node.h2.slug}
                >
                  <a href={`#${c.slug}`} data-toc-link={c.slug}>{c.text}</a>
                </li>
              ))}
            </ol>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc__label {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.8em;
    padding-bottom: 0.35em;
    border-bottom: 0.5px solid var(--border-faint);
  }
  .toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-ui);
    font-size: 12px;
    line-height: 1.55;
  }
  /* Nested H3 list: hidden by default, shown only for the currently-
     expanded H2 (the one that contains the active heading). */
  .toc__sub {
    list-style: none;
    padding: 0;
    margin: 0;
    display: none;
  }
  .toc__item[data-expanded='true'] > .toc__sub {
    display: block;
    margin-top: 0.25em;
    padding-bottom: 0.2em;
  }
  .toc__item {
    margin: 0.35em 0;
    border-left: 2px solid transparent;
    padding-left: 0.8em;
    margin-left: -0.8em;
    transition: border-color 120ms ease;
  }
  .toc__item[data-depth='3'] {
    padding-left: 1.6em;
    font-size: 11px;
    margin: 0.2em 0;
  }
  .toc__item a {
    color: var(--text-faint);
    text-decoration: none;
    transition: var(--t-link);
    display: block;
    padding: 1px 0;
  }
  .toc__item a:hover {
    color: var(--text-muted);
  }
  .toc__item.is-active {
    border-left-color: var(--text-muted);
  }
  .toc__item.is-active > a {
    color: var(--text);
  }
</style>

<script>
  (() => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.toc__item'));
    if (items.length === 0) return;

    // A post may render the TOC twice — once as the desktop sidebar and
    // once as the mobile <details> collapsible. Both point at the same
    // heading slugs, so the map is slug → all matching list items, and
    // is-active gets applied to every instance.
    const bySlug = new Map<string, HTMLElement[]>();
    for (const item of items) {
      const link = item.querySelector<HTMLAnchorElement>('a[data-toc-link]');
      const slug = link?.dataset.tocLink;
      if (!slug) continue;
      const bucket = bySlug.get(slug);
      if (bucket) bucket.push(item);
      else bySlug.set(slug, [item]);
    }
    const targets = Array.from(bySlug.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);
    if (targets.length === 0) return;

    // Collect H2 items keyed by slug so we can toggle data-expanded on the
    // node whose subsection is currently being read.
    const h2BySlug = new Map<string, HTMLElement[]>();
    for (const item of items) {
      if (item.dataset.depth !== '2') continue;
      const slug = item.dataset.slug;
      if (!slug) continue;
      const bucket = h2BySlug.get(slug);
      if (bucket) bucket.push(item);
      else h2BySlug.set(slug, [item]);
    }

    /** Given an active slug, return the H2 slug that should be expanded. */
    const h2ForActive = (slug: string): string | null => {
      const nodes = bySlug.get(slug);
      if (!nodes || nodes.length === 0) return null;
      const first = nodes[0];
      if (first.dataset.depth === '2') return slug;
      if (first.dataset.depth === '3') return first.dataset.parent ?? null;
      return null;
    };

    const visible = new Set<string>();
    let activeId: string | null = null;
    let expandedH2: string | null = null;

    const setExpanded = (h2Slug: string | null) => {
      if (h2Slug === expandedH2) return;
      if (expandedH2) {
        h2BySlug.get(expandedH2)?.forEach((el) => el.removeAttribute('data-expanded'));
      }
      if (h2Slug) {
        h2BySlug.get(h2Slug)?.forEach((el) => el.setAttribute('data-expanded', 'true'));
      }
      expandedH2 = h2Slug;
    };

    const setActive = (id: string | null) => {
      if (id === activeId) return;
      if (activeId) bySlug.get(activeId)?.forEach((el) => el.classList.remove('is-active'));
      if (id) bySlug.get(id)?.forEach((el) => el.classList.add('is-active'));
      activeId = id;
      setExpanded(id ? h2ForActive(id) : null);
    };

    const recompute = () => {
      if (visible.size === 0) return;
      // Topmost visible heading wins
      let best: { id: string; top: number } | null = null;
      for (const id of visible) {
        const el = document.getElementById(id);
        if (!el) continue;
        const top = el.getBoundingClientRect().top;
        if (!best || top < best.top) best = { id, top };
      }
      if (best) setActive(best.id);
    };

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        const id = (e.target as HTMLElement).id;
        if (!id) continue;
        if (e.isIntersecting) visible.add(id);
        else visible.delete(id);
      }
      recompute();
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    for (const t of targets) io.observe(t);
  })();
</script>
