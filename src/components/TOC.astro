---
export interface Props {
  headings: Array<{ depth: number; text: string; slug: string }>;
  /** Override label, default "目录". */
  label?: string;
}

const { headings, label = '目录' } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <nav class="toc" aria-label="文章目录">
    <p class="toc__label">{label}</p>
    <ol class="toc__list">
      {items.map((h) => (
        <li class="toc__item" data-depth={h.depth}>
          <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc__label {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.8em;
    padding-bottom: 0.35em;
    border-bottom: 0.5px solid var(--border-faint);
  }
  .toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-ui);
    font-size: 12px;
    line-height: 1.6;
  }
  .toc__item {
    margin: 0.4em 0;
    border-left: 2px solid transparent;
    padding-left: 0.8em;
    margin-left: -0.8em;
    transition: border-color 120ms ease;
  }
  .toc__item[data-depth='3'] {
    padding-left: 1.8em;
    font-size: 11.5px;
  }
  .toc__item a {
    color: var(--text-muted);
    text-decoration: none;
    transition: var(--t-link);
    display: block;
    padding: 1px 0;
  }
  .toc__item a:hover {
    color: var(--text);
  }
  .toc__item.is-active {
    border-left-color: var(--text-muted);
  }
  .toc__item.is-active > a {
    color: var(--text);
  }
</style>

<script>
  (() => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.toc__item'));
    if (items.length === 0) return;

    const byId = new Map<string, HTMLElement>();
    for (const item of items) {
      const link = item.querySelector<HTMLAnchorElement>('a[data-toc-link]');
      if (link?.dataset.tocLink) {
        byId.set(link.dataset.tocLink, item);
      }
    }
    const targets = Array.from(byId.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);
    if (targets.length === 0) return;

    const visible = new Set<string>();
    let activeId: string | null = null;

    const setActive = (id: string | null) => {
      if (id === activeId) return;
      if (activeId) byId.get(activeId)?.classList.remove('is-active');
      if (id) byId.get(id)?.classList.add('is-active');
      activeId = id;
    };

    const recompute = () => {
      if (visible.size === 0) return;
      // Topmost visible heading wins
      let best: { id: string; top: number } | null = null;
      for (const id of visible) {
        const el = document.getElementById(id);
        if (!el) continue;
        const top = el.getBoundingClientRect().top;
        if (!best || top < best.top) best = { id, top };
      }
      if (best) setActive(best.id);
    };

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        const id = (e.target as HTMLElement).id;
        if (!id) continue;
        if (e.isIntersecting) visible.add(id);
        else visible.delete(id);
      }
      recompute();
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    for (const t of targets) io.observe(t);
  })();
</script>
