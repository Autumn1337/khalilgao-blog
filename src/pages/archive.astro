---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { postUrl } from '../lib/post-url';
import { fmtMonthDay } from '../lib/date-format';

const all = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

type Post = CollectionEntry<'posts'>;
const byYear = new Map<number, Post[]>();
for (const p of all) {
  const y = p.data.pubDate.getFullYear();
  const bucket = byYear.get(y);
  if (bucket) bucket.push(p);
  else byYear.set(y, [p]);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
for (const year of years) {
  byYear
    .get(year)!
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
}
---

<BaseLayout title="归档" description="Khalil's Notes 的全部文章，按年份倒序。">
  <div class="archive container-prose">
    <h1 class="archive-title">归档</h1>
    {all.length === 0 ? (
      <p class="archive-empty">还没有文章。</p>
    ) : (
      years.map((year) => (
        <section class="archive-year">
          <h2>{year}</h2>
          <ul>
            {byYear.get(year)!.map((p) => (
              <li>
                <time datetime={p.data.pubDate.toISOString()}>
                  {fmtMonthDay(p.data.pubDate)}
                </time>
                <a href={postUrl(p)}>{p.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </div>
</BaseLayout>

<style>
  .archive {
    padding: 2.5rem 0 2rem;
  }
  .archive-title {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    line-height: var(--lh-h1);
    font-weight: 500;
    margin: 0 0 2.5rem;
    letter-spacing: -0.01em;
  }
  .archive-year {
    margin-bottom: 2.5rem;
  }
  .archive-year:last-child {
    margin-bottom: 0;
  }
  .archive-year h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    line-height: var(--lh-h2);
    font-weight: 500;
    margin: 0 0 0.9em;
    color: var(--text);
  }
  .archive-year ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .archive-year li {
    display: grid;
    grid-template-columns: 4.2rem 1fr;
    gap: 1.2rem;
    align-items: baseline;
    padding: 0.3em 0;
  }
  .archive-year li time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .archive-year li a {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.5;
  }
  .archive-year li a:hover {
    color: var(--link);
  }
  .archive-empty {
    font-family: var(--font-ui);
    color: var(--text-muted);
  }
  @media (max-width: 480px) {
    .archive-year li {
      grid-template-columns: 3.2rem 1fr;
      gap: 0.9rem;
    }
    .archive-year li a {
      font-size: 16px;
    }
  }
</style>
