---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { readingTime } from '../lib/reading-time';

const all = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sorted = all.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = sorted.slice(0, 5).map((p) => ({
  post: p,
  rt: readingTime(p.body),
}));
---

<BaseLayout title="Khalil's Notes">
  <div class="home container-prose">
    <section class="home-intro">
      <p>这里是 <strong>Khalil's Notes</strong>。</p>
      <p>
        在编码的间隙，我将脑海中路过的思绪一一截下，揉成文字。它们有时是一截优化的灵感，有时是一次弯路的复盘，有时仅仅是悟透某个技术点时，那电光石火的一瞬。我把这些片刻安放于此，赠给远方未来的自己，也赠给恰好经过的你。
      </p>
      <p class="home-intro__sig">Hewen Gao</p>
    </section>

    <section class="home-recent">
      <p class="section-label">最近文章</p>
      {recent.length === 0 ? (
        <p class="home-empty">还在写，先放着。</p>
      ) : (
        recent.map(({ post, rt }) => <PostCard post={post} readingTime={rt} />)
      )}
      {sorted.length > recent.length && (
        <p class="home-more">
          <a href="/archive/">全部文章 →</a>
        </p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    padding-block: 2.5rem 2rem;
  }
  .home-intro {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 4em;
    padding-bottom: 2.5em;
    border-bottom: 0.5px solid var(--border-faint);
  }
  .home-intro p {
    margin: 0.8em 0;
  }
  .home-intro strong {
    font-weight: 500;
  }
  .home-intro__sig {
    font-family: var(--font-ui);
    font-size: var(--fs-meta);
    color: var(--text-faint);
    margin-top: 1.6em !important;
  }
  .home-more {
    font-family: var(--font-ui);
    font-size: 13px;
    margin-top: 1em;
    text-align: right;
  }
  .home-more a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .home-more a:hover {
    color: var(--text);
  }
  .home-empty {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
</style>
