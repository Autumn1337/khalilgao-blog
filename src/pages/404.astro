---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { postUrl } from '../lib/post-url';
import { fmtMonthDay } from '../lib/date-format';

const all = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const recent = [...all]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="找不到页面">
  <div class="not-found container-prose">
    <p class="not-found__code">404</p>
    <h1>找不到页面</h1>
    <p class="not-found__note">你访问的地址不存在，可能是链接失效了。</p>
    <p class="not-found__back">
      <a href="/">← 返回首页</a>
    </p>

    {recent.length > 0 && (
      <section class="not-found__recent">
        <p class="section-label">最近文章</p>
        <ul>
          {recent.map((p) => (
            <li>
              <time datetime={p.data.pubDate.toISOString()}>
                {fmtMonthDay(p.data.pubDate)}
              </time>
              <a href={postUrl(p)}>{p.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .not-found {
    padding-block: 4rem 3rem;
    text-align: left;
  }
  .not-found__code {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.2em;
    color: var(--text-faint);
    margin: 0 0 0.4em;
  }
  .not-found h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    line-height: var(--lh-h1);
    font-weight: 500;
    margin: 0 0 1em;
  }
  .not-found__note {
    font-size: var(--fs-excerpt);
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0 0 1.2em;
  }
  .not-found__back {
    margin: 0 0 3rem;
  }
  .not-found__back a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-thickness: 0.5px;
    text-underline-offset: 2px;
  }
  .not-found__recent {
    margin-top: 2rem;
  }
  .not-found__recent ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .not-found__recent li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.1rem;
    align-items: baseline;
    padding: 0.3em 0;
  }
  .not-found__recent li time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .not-found__recent li a {
    color: var(--text);
    text-decoration: none;
    font-size: var(--fs-excerpt);
  }
  .not-found__recent li a:hover {
    color: var(--link);
  }
</style>
