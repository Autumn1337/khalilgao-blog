---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import Tag from '../components/Tag.astro';
import PostMeta from '../components/PostMeta.astro';
import Mermaid from '../components/Mermaid.astro';
import { fmtISODate } from '../lib/date-format';
import { postUrl } from '../lib/post-url';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'posts'>;
  headings: Array<{ depth: number; text: string; slug: string }>;
  prev?: CollectionEntry<'posts'> | null;
  next?: CollectionEntry<'posts'> | null;
  readingTime?: number;
}

const { post, headings, prev = null, next = null, readingTime } = Astro.props;
const d = post.data;
const tocHeadings = headings.filter(
  (h) => (h.depth === 2 || h.depth === 3) && h.slug !== 'footnote-label',
);
const showToc = d.toc !== false && tocHeadings.length > 0;
---

<BaseLayout
  title={d.title}
  description={d.description}
  lang={d.lang}
  article={{ pubDate: d.pubDate, updatedDate: d.updatedDate, tags: d.tags }}
>
  <article class="post">
    <div class="post-layout" data-has-toc={showToc ? 'true' : 'false'}>
      {showToc && (
        <aside class="post-toc-slot">
          <TOC headings={tocHeadings} />
        </aside>
      )}

      <div class="post-main">
        <header class="post-head">
          <h1 class="post-title">{d.title}</h1>
          <PostMeta post={post} readingTime={readingTime} showTags />
        </header>

        {showToc && (
          <details class="post-toc-mobile">
            <summary>目录</summary>
            <TOC headings={tocHeadings} hideLabel ariaLabel="文章目录（移动端）" />
          </details>
        )}

        <div class="post-body prose">
          <slot />
        </div>

        <footer class="post-foot">
          <hr class="post-foot__rule" />
          {d.tags.length > 0 && (
            <p class="post-tags">
              {d.tags.map((t) => <Tag tag={t} />)}
            </p>
          )}
          <p class="post-author">Hewen Gao · {fmtISODate(d.pubDate)}</p>
          {(prev || next) && (
            <nav class="post-prev-next" aria-label="相邻文章">
              {prev ? (
                <a class="pn pn--prev" href={postUrl(prev)}>
                  <span class="pn__label">← 上一篇</span>
                  <span class="pn__title">{prev.data.title}</span>
                </a>
              ) : <span />}
              {next ? (
                <a class="pn pn--next" href={postUrl(next)}>
                  <span class="pn__label">下一篇 →</span>
                  <span class="pn__title">{next.data.title}</span>
                </a>
              ) : <span />}
            </nav>
          )}
        </footer>
      </div>
    </div>
  </article>

  <Mermaid />

  <script>
    (async () => {
      const imgs = document.querySelectorAll<HTMLImageElement>('.post-body img');
      if (imgs.length === 0) return;
      const { default: mediumZoom } = await import('medium-zoom');
      mediumZoom(imgs, {
        margin: 24,
        background: 'var(--bg)',
        scrollOffset: 80,
      });
    })();
  </script>
</BaseLayout>

<style>
  .post {
    padding: 2.5rem 0 3.5rem;
  }

  /* Narrow screens: single column, no TOC sidebar. */
  .post-layout {
    max-width: var(--w-wide);
    margin-inline: auto;
    padding-inline: var(--pad-x);
  }

  /* Default: single-column prose. Children center themselves within
     the 680px prose measure; WideFigure/full-bleed grow beyond it via
     their own max-width. This shape works at every viewport AND inside
     the TOC sidebar layout where horizontal room is scarce. */
  .post-body > * {
    max-width: var(--w-prose);
    margin-inline: auto;
  }
  .post-body > :global(.wide-figure),
  .post-body > :global(figure.wide) {
    max-width: var(--w-wide);
  }
  .post-body > :global(.full-bleed) {
    max-width: none;
  }

  /* No-TOC pages on wide screens get the fancy 3-column breakout grid
     where WideFigure really hits 960px regardless of the prose column.
     TOC pages stay in the simple single-column flow above — there just
     isn't room for both a 200px sidebar AND a 960px breakout. */
  @media (min-width: 1100px) {
    .post-layout:not([data-has-toc='true']) .post-body {
      display: grid;
      grid-template-columns:
        [full-start] minmax(0, 1fr)
        [wide-start] minmax(0, calc((var(--w-wide) - var(--w-prose)) / 2))
        [prose-start] minmax(0, var(--w-prose)) [prose-end]
        minmax(0, calc((var(--w-wide) - var(--w-prose)) / 2)) [wide-end]
        minmax(0, 1fr) [full-end];
    }
    .post-layout:not([data-has-toc='true']) .post-body > * {
      grid-column: prose;
      max-width: none;
      margin-inline: 0;
      min-width: 0;
    }
    .post-layout:not([data-has-toc='true']) .post-body > :global(.wide-figure),
    .post-layout:not([data-has-toc='true']) .post-body > :global(figure.wide) {
      grid-column: wide;
    }
    .post-layout:not([data-has-toc='true']) .post-body > :global(.full-bleed) {
      grid-column: full;
    }
  }

  .post-head,
  .post-foot {
    max-width: var(--w-prose);
    margin-inline: auto;
    width: 100%;
  }

  .post-head {
    margin-bottom: 2.2rem;
  }
  .post-title {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    line-height: var(--lh-h1);
    font-weight: var(--fw-heading);
    margin: 0 0 0.7em;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .post-foot {
    margin-top: 3.5rem;
  }
  .post-foot__rule {
    border: 0;
    border-top: 0.5px solid var(--border);
    margin: 0 0 1.4em;
    max-width: none;
  }
  .post-tags {
    margin: 0 0 1em;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .post-author {
    font-family: var(--font-ui);
    font-size: var(--fs-meta);
    color: var(--text-faint);
    margin: 0 0 2em;
  }

  .post-prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .pn {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.75em 1em;
    border: 0.5px solid var(--border);
    border-radius: var(--r-btn);
    color: var(--text);
    font-size: 0.95em;
    line-height: 1.35;
    text-decoration: none;
  }
  .pn:hover {
    border-color: var(--text-muted);
  }
  .pn__label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--text-faint);
  }
  .pn__title {
    color: var(--text);
  }
  .pn--next {
    text-align: right;
  }

  @media (min-width: 1100px) {
    .post-layout[data-has-toc='true'] {
      display: grid;
      grid-template-columns: 200px minmax(0, 1fr);
      gap: 40px;
      max-width: var(--w-wide);
    }
    .post-toc-slot {
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 7rem);
      overflow-y: auto;
      padding-right: 0.5em;
    }
  }
  @media (max-width: 1099px) {
    .post-toc-slot { display: none; }
  }

  /* Mobile / tablet TOC — shows the same heading list as the desktop
     sidebar but collapses into a <details> block at the top of the
     article so narrow viewports still have navigation for long posts.
     Hidden on wide screens where the sticky sidebar takes over. */
  .post-toc-mobile {
    max-width: var(--w-prose);
    margin: 0 auto 2rem;
    padding: 0.55em 1em 0.55em 1em;
    border: 0.5px solid var(--border);
    border-radius: var(--r-btn);
    background: var(--bg);
    font-family: var(--font-ui);
  }
  .post-toc-mobile > summary {
    cursor: pointer;
    list-style: none;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.2em 0;
    user-select: none;
  }
  /* Hide native disclosure triangles across browsers. */
  .post-toc-mobile > summary::-webkit-details-marker { display: none; }
  .post-toc-mobile > summary::marker { content: ''; }
  .post-toc-mobile > summary::before {
    content: '▸';
    display: inline-block;
    width: 1em;
    margin-right: 0.2em;
    color: var(--text-faint);
    transition: transform 150ms ease;
  }
  .post-toc-mobile[open] > summary::before {
    transform: rotate(90deg);
  }
  .post-toc-mobile > :global(.toc) {
    margin-top: 0.6em;
    padding-top: 0.4em;
    border-top: 0.5px solid var(--border-faint);
  }
  @media (min-width: 1100px) {
    .post-toc-mobile { display: none; }
  }

  @media (max-width: 640px) {
    .post { padding: 1.5rem 0 2rem; }
    .post-head { margin-bottom: 1.5rem; }
    .post-prev-next { grid-template-columns: 1fr; }
    .pn--next { text-align: left; }
  }
</style>
