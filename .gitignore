# build output
dist/
.output/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment
.env
.env.production

# macOS
.DS_Store

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea
.project
.classpath
*.launch
.settings/
*.sublime-workspace

# Astro
.astro/

# Font subset source (fonts-source/) holds the pre-subset woff2 and
# the TTF copies used at build time by the OG-image route. It's
# tracked in git so `npm run subset-fonts` reproduces from a clean
# checkout — deliberately outside public/ so these multi-MB sources
# never ship to dist/.

# Codex plugin workspace marker
.codex

# Local-only operator notes (runbooks etc.) — must not reach public repo
docs/local/

# Session handoff state — local-only, managed by handoff plugin
docs/handoff/

# Draft staging — .md drafts here get converted + moved into src/content/posts/
# by the AI; the raw inputs never need to ship to GitHub. README stays tracked.
needtosubmit/*
!needtosubmit/README.md
